.aiapps-marquee {
  overflow: hidden;
  white-space: nowrap;
  padding: 12px 0;
  background: linear-gradient(90deg, rgba(13,148,136,.08), rgba(245,158,11,.08));
}

.aiapps-marquee-track {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  width: max-content;
  animation: aiappsMarqueeMove 28s linear infinite;
}

.aiapps-marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid rgba(148,163,184,.22);
  background: rgba(255,255,255,.72);
  color: #0f172a;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .02em;
  box-shadow: 0 4px 16px rgba(15,23,42,.05);
}

.aiapps-marquee-item span {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #0d9488;
  display: inline-block;
}

@keyframes aiappsMarqueeMove {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

.aiapps-shell {
  margin-top: 24px;
  position: relative;
  text-align: center;
}

.aiapps-hint {
  margin-bottom: 10px;
  text-align: center;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: #0f766e;
}

.aiapps-row {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: clamp(8px, 1.65vw, 22px);
  min-height: 255px;
  padding-top: 54px;
  transition: transform .82s cubic-bezier(.22,.68,0,1), opacity .82s ease;
}

.aiapps-row.aiapps-moving {
  transform: translateX(18px);
  opacity: .96;
}

.aiapps-item {
  position: relative;
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
}

.aiapps-bubble {
  position: relative;
  display: grid;
  place-items: center;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.78);
  overflow: visible;
  transition: width .28s ease, height .28s ease, opacity .28s ease, filter .28s ease, transform .28s ease, box-shadow .28s ease;
}

.aiapps-halo {
  position: absolute;
  inset: 8%;
  border-radius: 999px;
  filter: blur(16px);
  opacity: .46;
  z-index: 0;
}

.aiapps-logo {
  position: relative;
  z-index: 1;
  width: 84%;
  height: 84%;
  object-fit: contain;
  display: block;
}

.aiapps-active .aiapps-bubble {
  width: 169px;
  height: 169px;
  opacity: 1;
  filter: saturate(1);
}

.aiapps-near-1 .aiapps-bubble {
  width: 108px;
  height: 108px;
  opacity: .66;
  filter: saturate(.88);
}

.aiapps-near-2 .aiapps-bubble {
  width: 88px;
  height: 88px;
  opacity: .52;
  filter: saturate(.78);
}

.aiapps-far-1 .aiapps-bubble {
  width: 70px;
  height: 70px;
  opacity: .36;
  filter: saturate(.64);
}

.aiapps-far-2 .aiapps-bubble {
  width: 54px;
  height: 54px;
  opacity: .24;
  filter: saturate(.50);
}

.aiapps-tagline {
  display: block;
  margin: 18px auto 0;
  width: 100%;
  text-align: center;
  font-size: 16px;
  font-weight: 900;
  color: #0f766e;
  line-height: 1.3;
}

.aiapps-tooltip {
  position: absolute;
  left: 50%;
  bottom: calc(100% + 14px);
  width: min(380px, 82vw);
  transform: translateX(-50%) translateY(8px);
  padding: 13px 15px;
  border-radius: 16px;
  background: rgba(15, 23, 42, .95);
  color: white;
  text-align: center;
  box-shadow: 0 18px 38px rgba(15,23,42,.18), 0 0 0 1px rgba(255,255,255,.10) inset;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .22s ease, visibility .22s ease, transform .22s ease;
  z-index: 999;
}

.aiapps-tooltip::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -7px;
  width: 14px;
  height: 14px;
  transform: translateX(-50%) rotate(45deg);
  background: rgba(15, 23, 42, .95);
}

.aiapps-tooltip strong {
  display: block;
  font-size: 13px;
  line-height: 1.25;
  margin-bottom: 6px;
  color: #67e8f9;
}

.aiapps-tooltip p {
  margin: 0;
  font-size: 11px;
  line-height: 1.48;
  color: rgba(255,255,255,.86);
}

.aiapps-active:hover .aiapps-tooltip {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

.aiapps-dots {
  margin-top: 14px;
  display: flex;
  justify-content: center;
  gap: 8px;
}

.aiapps-dots span {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #cbd5e1;
}

.aiapps-dots span.active {
  width: 32px;
  background: #0f766e;
}

@media (max-width: 900px) {
  .aiapps-row {
    gap: 8px;
  }

  .aiapps-active .aiapps-bubble {
    width: 130px;
    height: 130px;
  }

  .aiapps-near-1 .aiapps-bubble {
    width: 86px;
    height: 86px;
  }

  .aiapps-near-2 .aiapps-bubble {
    width: 70px;
    height: 70px;
  }

  .aiapps-far-1 .aiapps-bubble {
    width: 54px;
    height: 54px;
  }

  .aiapps-far-2 .aiapps-bubble {
    width: 42px;
    height: 42px;
  }
}

@media (max-width: 620px) {
  .aiapps-row {
    gap: 5px;
    min-height: 220px;
    padding-top: 46px;
  }

  .aiapps-active .aiapps-bubble {
    width: 104px;
    height: 104px;
  }

  .aiapps-near-1 .aiapps-bubble {
    width: 68px;
    height: 68px;
  }

  .aiapps-near-2 .aiapps-bubble {
    width: 54px;
    height: 54px;
  }

  .aiapps-far-1 .aiapps-bubble {
    width: 42px;
    height: 42px;
  }

  .aiapps-far-2 .aiapps-bubble {
    width: 34px;
    height: 34px;
  }

  .aiapps-tagline {
    font-size: 13px;
  }

  .aiapps-tooltip {
    width: min(300px, 90vw);
    padding: 11px 12px;
  }

  .aiapps-tooltip strong {
    font-size: 11px;
  }

  .aiapps-tooltip p {
    font-size: 9.5px;
    line-height: 1.38;
  }
}