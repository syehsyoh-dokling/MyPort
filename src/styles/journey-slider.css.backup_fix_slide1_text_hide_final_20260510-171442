/* ==========================================================
   CLEAN JOURNEY SLIDER CSS
   Rebuilt compactly after patch stack cleanup
   ========================================================== */

#journey {
  --journey-duration: 3000ms;
  --journey-walk-start: 4%;
  --journey-walk-end: 30%;
  --journey-accent: #0c67d8;
  --journey-accent-soft: rgba(12,103,216,.14);
  --journey-frame-y: 0px;

  color: #0f172a;
}

#journey * {
  box-sizing: border-box;
}

.journey-grid {
  display: grid;
  grid-template-columns: minmax(290px, 0.9fr) minmax(520px, 1.45fr);
  gap: 24px;
  align-items: stretch;
}

.journey-story {
  min-height: 640px;
  padding: 26px;
  border-radius: 28px;
  background: linear-gradient(180deg, rgba(255,255,255,.92), rgba(239,246,255,.82));
  border: 1px solid rgba(148,163,184,.28);
  box-shadow: 0 20px 60px rgba(15,23,42,.12);
  overflow: hidden;
}

.journey-eyebrow {
  margin: 0 0 16px 0;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: #2563eb;
}

.journey-story p {
  margin: 0;
  font-size: 14px;
  line-height: 1.72;
  color: #334155;
}

.journey-motto {
  margin-top: 18px;
  padding: 14px 16px;
  border-radius: 18px;
  background: rgba(37,99,235,.08);
  color: #1d4ed8;
  font-weight: 800;
  line-height: 1.35;
}

.journey-control-row {
  margin-top: 22px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.journey-nav-btn,
.journey-primary,
.journey-mini-btn {
  appearance: none;
  border: 0;
  cursor: pointer;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #0ea5e9);
  box-shadow: 0 10px 24px rgba(37,99,235,.24);
  transition: transform .18s ease, filter .18s ease;
}

.journey-nav-btn {
  width: 38px;
  height: 38px;
}

.journey-mini-btn,
.journey-primary {
  min-height: 38px;
  padding: 0 14px;
  font-size: 12px;
  font-weight: 800;
}

.journey-nav-btn:hover,
.journey-primary:hover {
  transform: translateY(-1px);
  filter: brightness(1.03);
}

.journey-dots {
  display: flex;
  gap: 6px;
  align-items: center;
  max-width: 200px;
  overflow: hidden;
}

.journey-dot {
  width: 8px;
  height: 8px;
  border: 0;
  border-radius: 999px;
  background: rgba(15,23,42,.18);
  cursor: pointer;
  padding: 0;
}

.journey-dot.active {
  width: 22px;
  background: #2563eb;
}

.journey-actions-inline {
  display: flex;
  gap: 8px;
}

.journey-progress {
  margin-top: 18px;
  width: 100%;
  height: 6px;
  border-radius: 999px;
  background: rgba(15,23,42,.08);
  overflow: hidden;
}

.journey-progress-bar {
  height: 100%;
  width: 0%;
  border-radius: 999px;
  background: linear-gradient(90deg, #2563eb, #22c55e);
  animation: journeyProgress var(--journey-duration) linear forwards;
}

.journey-panel {
  position: relative;
  min-height: 640px;
  border-radius: 30px;
  overflow: hidden;
  isolation: isolate;
  background:
    linear-gradient(135deg, rgba(223,248,255,.24), rgba(231,255,246,.20)),
    linear-gradient(135deg, #e0f2fe, #f8fafc 50%, #dcfce7);
  border: 1px solid rgba(148,163,184,.28);
  box-shadow: 0 24px 80px rgba(15,23,42,.16);
}

.journey-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 18% 16%, rgba(255,255,255,.9), transparent 26%),
    radial-gradient(circle at 80% 10%, rgba(14,165,233,.18), transparent 30%),
    linear-gradient(180deg, rgba(255,255,255,.24), transparent 45%);
  z-index: 0;
}

.journey-code-stack {
  position: absolute;
  top: 26px;
  left: 28px;
  right: 28px;
  z-index: 10;
  opacity: 0;
  transform: translateY(14px);
  animation: journeyCodeStackIn .55s ease forwards;
}

.journey-code-year {
  font-size: clamp(38px, 5vw, 72px);
  line-height: .95;
  font-weight: 950;
  letter-spacing: -0.06em;
  color: #0f172a;
  text-shadow: 0 2px 0 rgba(255,255,255,.35);
}

.journey-code-year .accent-word {
  color: var(--journey-accent);
}

.journey-code-place {
  margin-top: 10px;
  max-width: 70%;
  font-size: clamp(15px, 2vw, 24px);
  line-height: 1.2;
  font-weight: 850;
  color: #1e293b;
}

.journey-visual-track {
  position: absolute;
  left: 0;
  right: 0;
  top: 120px;
  bottom: 178px;
  z-index: 4;
  overflow: visible;
}

.journey-visual-item {
  position: absolute;
  left: -260px;
  bottom: 0;
  width: 240px;
  height: 320px;
  z-index: 5;
  transition: opacity .25s ease;
}

.journey-character-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center bottom;
  pointer-events: none;
  user-select: none;
}

.journey-shadow {
  position: absolute;
  left: 6%;
  bottom: 0;
  width: 120px;
  height: 20px;
  border-radius: 999px;
  background: rgba(15,23,42,.18);
  filter: blur(5px);
  z-index: 2;
  opacity: .72;
}

.journey-ground {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 154px;
  height: 6px;
  z-index: 3;
  background: linear-gradient(90deg, transparent, rgba(15,23,42,.18), transparent);
}

/* Walk mode */
.journey-panel.walk .journey-visual-track {
  top: 118px;
  bottom: 176px;
  overflow: visible;
}

.journey-panel.walk .journey-visual-item {
  position: absolute;
  width: 221px;
  height: 293px;
  bottom: 72px;
  left: var(--journey-walk-start);
  opacity: 1;
  visibility: visible;
  animation:
    var(--journey-walk-animation) var(--journey-duration) linear forwards,
    journeyBodyBounce .58s ease-in-out infinite;
  will-change: left, transform;
}

.journey-panel.walk.walk-done .journey-visual-item {
  animation: none !important;
  left: var(--journey-walk-end);
}

.journey-panel.walk .journey-character-img {
  display: block;
  width: 221px;
  height: 293px;
  max-width: 221px;
  max-height: 293px;
  object-fit: contain;
  object-position: center bottom;
}

.journey-panel.walk .journey-shadow {
  width: 150px;
  height: 24px;
  bottom: 64px;
  left: calc(var(--journey-walk-start) + 2%);
  animation: journeyShadowAcross var(--journey-duration) linear forwards;
}
/* Bus mode */
.journey-panel.bus .journey-visual-track {
  top: 120px;
  bottom: 160px;
}

.journey-panel.bus .journey-visual-item {
  width: min(42vw, 440px);
  height: min(30vh, 250px);
  left: auto;
  right: 10%;
  bottom: -6px;
  animation: journeyBusDrive 3000ms cubic-bezier(.22,.72,.18,1) forwards;
}

.journey-panel.bus .journey-character-img {
  object-fit: contain;
  object-position: center bottom;
}

.journey-panel.bus .journey-shadow {
  display: none;
}

/* Opening / scene / split */
.journey-panel.opening .journey-visual-track,
.journey-panel.scene .journey-visual-track,
.journey-panel.split .journey-visual-track {
  top: 118px;
  bottom: 178px;
  display: grid;
  place-items: center;
}

.journey-panel.opening .journey-visual-item,
.journey-panel.scene .journey-visual-item,
.journey-panel.split .journey-visual-item {
  position: relative;
  left: auto;
  bottom: auto;
  width: min(620px, 88%);
  height: min(340px, 100%);
}

.journey-panel.opening .journey-character-img,
.journey-panel.scene .journey-character-img,
.journey-panel.split .journey-character-img {
  object-fit: contain;
}

/* Achievement */
.journey-panel.achievement .journey-visual-track {
  top: 110px;
  bottom: 210px;
  display: grid;
  grid-template-columns: minmax(260px, 1.2fr) minmax(200px, .8fr);
  gap: 16px;
  padding: 0 28px;
  align-items: end;
}

.journey-panel.achievement .journey-visual-item {
  position: absolute;
  width: 300px;
  height: 380px;
  left: 76%;
  bottom: 142px;
  transform: translateX(-50%);
}

.journey-panel.achievement .journey-character-img {
  width: 300px;
  height: 380px;
  max-width: 300px;
  max-height: 380px;
  object-fit: contain;
  object-position: center bottom;
}

.journey-notes {
  position: absolute;
  left: 28px;
  top: 66px;
  width: min(62%, 680px);
  max-width: 680px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 12;
  pointer-events: none;
}

.journey-note {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  min-height: 54px;
  padding: 11px 14px;
  border-radius: 16px;
  background: rgba(255,255,255,.84);
  border: 1px solid rgba(148,163,184,.26);
  box-shadow: 0 10px 24px rgba(15,23,42,.12);
  opacity: 0;
  transform: translateY(10px);
  animation: journeyNoteIn .42s ease forwards;
}

.journey-note.exit {
  animation: journeyNoteOut .42s ease forwards;
}

.journey-note span {
  min-width: 36px;
  width: 36px;
  height: 36px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(37,99,235,.10);
  color: #1d4ed8;
  font-size: 18px;
  font-weight: 900;
}

.journey-note p {
  margin: 0;
  color: #1e293b;
  font-size: 13px;
  line-height: 1.3;
}

/* Footer */
.journey-slide-footer {
  position: absolute;
  left: 18px;
  right: 18px;
  bottom: 22px;
  z-index: 30;

  min-height: 178px;
  height: 178px;
  padding: 20px 22px;

  display: grid;
  grid-template-columns: 120px minmax(170px, 240px) 1fr;
  grid-template-rows: auto auto;
  column-gap: 16px;
  row-gap: 7px;
  align-items: start;

  overflow: visible;
  border-radius: 0 0 24px 24px;
  background:
    linear-gradient(180deg, rgba(8,18,38,.12) 0%, rgba(10,22,45,.90) 28%, rgba(8,18,38,.98) 100%);
  color: #ffffff;
  box-sizing: border-box;
}

.journey-footer-badge {
  grid-column: 1;
  grid-row: 1 / span 2;
  display: block;
  font-size: 11px;
  line-height: 1.22;
  letter-spacing: .08em;
  text-transform: uppercase;
  font-weight: 900;
  color: #bfdbfe;
  white-space: normal;
}

.journey-footer-meta {
  grid-column: 2;
  grid-row: 1 / span 2;
  display: block;
  min-width: 0;
}

.journey-footer-meta strong,
.journey-footer-meta span {
  display: block;
  white-space: normal;
  overflow: visible;
  text-overflow: unset;
}

.journey-footer-meta strong {
  font-size: 13px;
  line-height: 1.22;
  margin-bottom: 4px;
  color: #ffffff;
}

.journey-footer-meta span {
  font-size: 11.5px;
  line-height: 1.28;
  color: rgba(226,232,240,.88);
}

.journey-slide-footer h3 {
  grid-column: 3;
  grid-row: 1;
  display: block;
  margin: 0;
  padding: 0;
  font-size: 19px;
  line-height: 1.18;
  color: #ffffff;
  white-space: normal;
  overflow: visible;
  text-overflow: unset;
}

.journey-slide-footer h3 span {
  color: #93c5fd;
}

.journey-slide-footer p {
  grid-column: 3;
  grid-row: 2;
  display: block;
  margin: 4px 0 0 0;
  padding: 0;
  font-size: 13px;
  line-height: 1.34;
  color: rgba(226,232,240,.92);
  white-space: normal;
  overflow: visible;
  text-overflow: unset;
}

.journey-panel.achievement .journey-slide-footer {
  height: 188px;
  min-height: 188px;
}

/* Plane */
.plane-svg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 8;
  opacity: 0;
}

.plane-svg.grad,
.plane-svg.takeoff,
.plane-svg.fly,
.plane-svg.land {
  opacity: 1;
}

.plane-svg.takeoff {
  animation: journeySvgTakeoff 3.2s ease forwards;
}

.plane-svg.fly {
  animation: journeySvgFly 3.2s ease forwards;
}

.plane-svg.land {
  animation: journeySvgLand 3.2s ease forwards;
}

/* Keyframes */
@keyframes journeyProgress {
  from { width: 0; }
  to { width: 100%; }
}

@keyframes journeyCodeStackIn {
  to { opacity: 1; transform: translateY(0); }
}

@keyframes journeyWalkAcross {
  from { left: var(--journey-walk-start); }
  to { left: var(--journey-walk-end); }
}

@keyframes journeyShadowAcross {
  from { left: calc(var(--journey-walk-start) + 2%); }
  to { left: calc(var(--journey-walk-end) + 2%); }
}

@keyframes journeyBodyBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes journeyBusDrive {
  0% { opacity: 0; transform: translateX(180px) translateY(4px) scale(.92); }
  55% { opacity: 1; transform: translateX(20px) translateY(0) scale(1.02); }
  100% { opacity: 1; transform: translateX(0) translateY(0) scale(1); }
}

@keyframes journeyNoteIn {
  to { opacity: 1; transform: translateY(0); }
}

@keyframes journeyNoteOut {
  to { opacity: 0; transform: translateY(-12px); }
}

@keyframes journeySvgTakeoff {
  from { transform: translate(-20%, 18%) scale(.8); opacity: 0; }
  to { transform: translate(26%, -22%) scale(1.05); opacity: 1; }
}

@keyframes journeySvgFly {
  from { transform: translate(-30%, -10%) scale(.9); opacity: 0; }
  to { transform: translate(24%, -12%) scale(1); opacity: 1; }
}

@keyframes journeySvgLand {
  from { transform: translate(-20%, -24%) scale(.9); opacity: 0; }
  to { transform: translate(22%, 16%) scale(1); opacity: 1; }
}

/* Responsive */
@media (max-width: 1024px) {
  .journey-grid {
    grid-template-columns: 1fr;
  }

  .journey-story,
  .journey-panel {
    min-height: 620px;
  }
}

@media (max-width: 900px) {
  .journey-panel.walk .journey-visual-item {
    width: 179px;
    height: 242px;
    bottom: 78px;
  }

  .journey-panel.walk .journey-character-img {
    width: 179px;
    height: 242px;
    max-width: 179px;
    max-height: 242px;
  }

  .journey-slide-footer {
    left: 14px;
    right: 14px;
    bottom: 18px;
    min-height: 180px;
    height: 180px;
    grid-template-columns: 90px minmax(120px, 180px) 1fr;
    column-gap: 12px;
    padding: 18px 16px;
  }

  .journey-slide-footer h3 {
    font-size: 15.5px;
  }

  .journey-slide-footer p {
    font-size: 12px;
  }

  .journey-panel.achievement .journey-visual-item {
    width: 220px;
    height: 286px;
    left: 73%;
    bottom: 154px;
  }

  .journey-panel.achievement .journey-character-img {
    width: 220px;
    height: 286px;
    max-width: 220px;
    max-height: 286px;
  }
}

@media (max-width: 640px) {
  #journey {
    padding-left: 12px;
    padding-right: 12px;
  }

  .journey-story,
  .journey-panel {
    min-height: 660px;
    border-radius: 24px;
  }

  .journey-story {
    padding: 20px;
  }

  .journey-code-stack {
    top: 18px;
    left: 18px;
    right: 18px;
  }

  .journey-code-place {
    max-width: 94%;
  }

  .journey-visual-track {
    top: 125px;
    bottom: 204px;
  }

  .journey-panel.walk .journey-visual-item {
    width: 146px;
    height: 202px;
    bottom: 92px;
  }

  .journey-panel.walk .journey-character-img {
    width: 146px;
    height: 202px;
    max-width: 146px;
    max-height: 202px;
  }

  .journey-slide-footer {
    left: 10px;
    right: 10px;
    bottom: 14px;
    min-height: 204px;
    height: 204px;
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto auto;
    row-gap: 5px;
    padding: 14px 14px 16px 14px;
  }

  .journey-footer-badge,
  .journey-footer-meta,
  .journey-slide-footer h3,
  .journey-slide-footer p {
    grid-column: 1;
  }

  .journey-footer-badge {
    grid-row: 1;
    font-size: 9.5px;
  }

  .journey-footer-meta {
    grid-row: 2;
  }

  .journey-slide-footer h3 {
    grid-row: 3;
    font-size: 14px;
  }

  .journey-slide-footer p {
    grid-row: 4;
    font-size: 11px;
  }

  .journey-panel.achievement .journey-visual-item {
    width: 155px;
    height: 218px;
    left: 77%;
    bottom: 190px;
  }

  .journey-panel.achievement .journey-character-img {
    width: 155px;
    height: 218px;
    max-width: 155px;
    max-height: 218px;
  }

  .journey-notes {
    left: 10px;
    top: 54px;
    width: 66%;
  }

  .journey-note {
    min-height: 46px;
    padding: 8px 9px;
  }

  .journey-note span {
    min-width: 30px;
    width: 30px;
    height: 30px;
    font-size: 15px;
  }

  .journey-note p {
    font-size: 11px;
  }
}

/* ==========================================================
   PATCH - 24 SLIDE RESPONSIVE LAYOUT
   - Compact laptop one-screen layout
   - Smaller animated header/date
   - Footer 1-column feel for life slides
   - Footer 2-column feel for professional slides
   - Split slide image/text collision prevention
   ========================================================== */

#journey {
  padding-block: clamp(10px, 1.5vh, 18px) !important;
}

#journey .journey-grid {
  min-height: calc(100vh - 96px) !important;
  align-items: stretch !important;
}

#journey .journey-story,
#journey .journey-panel {
  min-height: min(620px, calc(100vh - 128px)) !important;
}

#journey .journey-story {
  padding: clamp(18px, 2vw, 24px) !important;
}

#journey .journey-code-stack {
  top: clamp(20px, 3vh, 34px) !important;
  left: clamp(22px, 3vw, 36px) !important;
  right: clamp(22px, 3vw, 36px) !important;
}

#journey .journey-code-year {
  font-size: clamp(34px, 4.5vw, 68px) !important;
  line-height: .94 !important;
  letter-spacing: -0.055em !important;
  background: linear-gradient(90deg, #0f172a 0%, var(--journey-accent, #2563eb) 72%, #38bdf8 100%) !important;
  -webkit-background-clip: text !important;
  background-clip: text !important;
  color: transparent !important;
  animation: journeyHeaderSoftReveal .8s ease both !important;
}

#journey .journey-code-place {
  max-width: min(74%, 720px) !important;
  font-size: clamp(15px, 1.75vw, 24px) !important;
  line-height: 1.18 !important;
  animation: journeyHeaderSoftReveal .95s ease both !important;
}

#journey .journey-slide-footer {
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  border-radius: 0 0 30px 30px !important;
  min-height: 132px !important;
  height: 132px !important;
  padding: 18px 28px 18px 28px !important;
  background:
    linear-gradient(180deg, rgba(15,23,42,0) 0%, rgba(15,23,42,.62) 18%, rgba(8,18,38,.98) 100%) !important;
}

#journey .journey-panel.split .journey-slide-footer,
#journey .journey-panel.logo .journey-slide-footer {
  min-height: 146px !important;
  height: 146px !important;
  grid-template-columns: minmax(220px, 0.62fr) minmax(360px, 1.38fr) !important;
  grid-template-rows: auto auto !important;
  column-gap: 24px !important;
}

#journey .journey-panel.split .journey-footer-badge,
#journey .journey-panel.logo .journey-footer-badge {
  grid-column: 1 !important;
  grid-row: 1 !important;
  font-size: 10px !important;
}

#journey .journey-panel.split .journey-footer-meta,
#journey .journey-panel.logo .journey-footer-meta {
  grid-column: 1 !important;
  grid-row: 2 !important;
}

#journey .journey-panel.split .journey-slide-footer h3,
#journey .journey-panel.logo .journey-slide-footer h3 {
  grid-column: 2 !important;
  grid-row: 1 !important;
  font-size: clamp(15px, 1.45vw, 21px) !important;
  line-height: 1.16 !important;
}

#journey .journey-panel.split .journey-slide-footer p,
#journey .journey-panel.logo .journey-slide-footer p {
  grid-column: 2 !important;
  grid-row: 2 !important;
  font-size: clamp(11px, 1vw, 13px) !important;
  line-height: 1.3 !important;
}

#journey .journey-panel.opening .journey-slide-footer,
#journey .journey-panel.bus .journey-slide-footer,
#journey .journey-panel.walk .journey-slide-footer,
#journey .journey-panel.scene .journey-slide-footer,
#journey .journey-panel.plane .journey-slide-footer,
#journey .journey-panel.achievement .journey-slide-footer {
  grid-template-columns: 1fr !important;
  grid-template-rows: auto auto auto !important;
  row-gap: 4px !important;
}

#journey .journey-panel.opening .journey-footer-badge,
