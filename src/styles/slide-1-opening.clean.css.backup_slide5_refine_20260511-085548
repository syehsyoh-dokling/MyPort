/* Slide 2 bus choreography:
   - frame-1 starts at far top-right and moves left to middle stop
   - frame-1 fades out at the stop point
   - frame-3 takes over from the middle stop and continues to the final left position */
#journey .journey-panel[data-slide-index="1"] .journey-bus-duo {
  position: absolute !important;
  inset: 0 !important;
  z-index: 12 !important;
  overflow: hidden !important;
}

