@keyframes openingBgEnter {
  0% { opacity: 0; transform: scale(.30) rotate(-540deg); filter: saturate(1.08) brightness(1.08); }
  45% { opacity: 1; transform: scale(1.14) rotate(-115deg); filter: saturate(1.05) brightness(1.06); }
  78% { opacity: 1; transform: scale(1.025) rotate(-12deg); filter: saturate(1.02) brightness(1.04); }
  100% { opacity: 1; transform: scale(1) rotate(0deg); filter: saturate(1.02) brightness(1.03); }
}

@keyframes openingBgVaporOut {
  0% { opacity: 1; transform: scale(1) rotate(0deg); filter: saturate(1.02) brightness(1.03) blur(0); }
  42% { opacity: .72; transform: scale(1.035) rotate(.5deg); filter: saturate(1.05) brightness(1.12) blur(4px); }
  100% { opacity: 0; transform: scale(1.09) rotate(1.2deg); filter: saturate(.88) brightness(1.25) blur(18px); }
}

@keyframes openingTypeOne { 0% { opacity: 1; width: 0; } 100% { opacity: 1; width: 31ch; } }
@keyframes openingTypeTwo { 0% { opacity: 1; width: 0; } 100% { opacity: 1; width: 47ch; } }
@keyframes openingCaret { 50% { border-right-color: transparent; } }
@keyframes openingNameReveal { to { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes openingFooterReveal { to { opacity: 1; transform: translateY(0); } }
@keyframes openingFooterLine { to { opacity: 1; transform: translateY(0); } }

@keyframes slide2BusLead {
  0% { transform: translateX(0) translateY(0) scale(.98); }
  100% { transform: translateX(-44vw) translateY(-2px) scale(1.02); }
}

@keyframes slide2BusFollow {
  0% { opacity: 0; transform: translateX(0) translateY(0) scale(.92); }
  14% { opacity: 1; }
  100% { opacity: 1; transform: translateX(-20vw) translateY(-2px) scale(1.11); }
}

