/* ============================================================
   CLEAN OPENING FLOW - SLIDE 1 & 2 ONLY
   Slide index 0 = Opening / Birth
   Slide index 1 = Move to Sabang
   ============================================================ */

/* -------------------------
   SLIDE 1: cinematic opening
   ------------------------- */
#journey .journey-panel[data-slide-index="0"] {
  position: relative !important;
  overflow: hidden !important;
  isolation: isolate !important;
  background: #020617 !important;
  background-image: none !important;
}

#journey .journey-panel[data-slide-index="0"]::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background: url("/assets/slide-0/background.png") center / cover no-repeat;
  transform-origin: center;
  animation:
    openingBgEnter 1080ms cubic-bezier(.12,.92,.12,1) both,
    openingBgVaporOut 560ms cubic-bezier(.55,.02,.85,.42) 11050ms forwards;
  will-change: transform, opacity;
}

#journey .journey-panel[data-slide-index="0"]::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    radial-gradient(circle at 50% 28%, rgba(255,255,255,.10), transparent 34%),
    linear-gradient(180deg, rgba(2,6,23,.02), rgba(2,6,23,.20));
}

#journey .journey-panel[data-slide-index="0"] > * {
  position: relative;
  z-index: 2;
}

#journey .journey-panel[data-slide-index="0"] .journey-visual-track,
#journey .journey-panel[data-slide-index="0"] .journey-visual-item,
#journey .journey-panel[data-slide-index="0"] .journey-character-img,
#journey .journey-panel[data-slide-index="0"] .journey-ground,
#journey .journey-panel[data-slide-index="0"] .journey-shadow,
#journey .journey-panel[data-slide-index="0"] .journey-notes,
#journey .journey-panel[data-slide-index="0"] .journey-achievement-heading {
  display: none !important;
}

#journey .journey-panel[data-slide-index="0"] .journey-opening-prologue {
  position: absolute !important;
  inset: 0 !important;
  z-index: 40 !important;
  pointer-events: none !important;
}

#journey .journey-panel[data-slide-index="0"] .journey-opening-line {
  position: absolute !important;
  left: 50% !important;
  display: inline-block !important;
  max-width: 92% !important;
  overflow: hidden !important;
  white-space: nowrap !important;
  transform: translateX(-50%) !important;
  color: #fff !important;
  font-size: clamp(20px, 3vw, 38px) !important;
  line-height: 1.16 !important;
  font-weight: 950 !important;
  letter-spacing: -.02em !important;
  text-align: center !important;
  text-shadow: 0 14px 34px rgba(0,0,0,.62), 0 4px 10px rgba(0,0,0,.52) !important;
  border-right: 0 !important;
  opacity: 0;
  width: 0;
}

#journey .journey-panel[data-slide-index="0"] .journey-opening-line--one {
  top: 28% !important;
  animation:
    openingTypeOne 3000ms steps(31, end) 1500ms both;
}

#journey .journey-panel[data-slide-index="0"] .journey-opening-line--two {
  top: 38% !important;
  animation:
    openingTypeTwo 3600ms steps(47, end) 4700ms both;
}

#journey .journey-panel[data-slide-index="0"] .journey-code-stack {
  position: absolute !important;
  left: 5.5% !important;
  right: 5.5% !important;
  top: 8% !important;
  z-index: 42 !important;
  opacity: 0;
  transform: translateY(18px) scale(.98);
  animation: openingNameReveal 850ms ease 7600ms both;
}

#journey .journey-panel[data-slide-index="0"] .journey-code-year {
  color: #fff !important;
  background: none !important;
  -webkit-background-clip: initial !important;
  background-clip: initial !important;
  font-size: clamp(29px, 4.1vw, 54px) !important;
  line-height: .98 !important;
  letter-spacing: -.045em !important;
  text-shadow: 0 18px 42px rgba(0,0,0,.60), 0 4px 10px rgba(0,0,0,.48) !important;
}

#journey .journey-panel[data-slide-index="0"] .journey-code-year::after,
#journey .journey-panel[data-slide-index="0"] .journey-code-place {
  display: none !important;
}

#journey .journey-panel[data-slide-index="0"] .journey-name-small {
  color: #fbbf24 !important;
  font-size: .74em !important;
  letter-spacing: -.04em !important;
}

#journey .journey-panel[data-slide-index="0"] .journey-slide-footer {
  position: absolute !important;
  left: 5.5% !important;
  right: 5.5% !important;
  bottom: 24px !important;
  z-index: 44 !important;
  width: auto !important;
  min-height: 0 !important;
  padding: 14px 16px !important;
