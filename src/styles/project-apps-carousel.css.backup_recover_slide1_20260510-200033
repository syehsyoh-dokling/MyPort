.projectapps-marquee {
  overflow: hidden;
  white-space: nowrap;
  padding: 12px 0;
  background: linear-gradient(90deg, rgba(13,148,136,.08), rgba(245,158,11,.08));
}

.projectapps-marquee-track {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  width: max-content;
  animation: projectappsMarqueeMove 28s linear infinite;
}

.projectapps-marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid rgba(148,163,184,.22);
  background: rgba(255,255,255,.72);
  color: #0f172a;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .02em;
  box-shadow: 0 4px 16px rgba(15,23,42,.05);
}

.projectapps-marquee-item span {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #0d9488;
  display: inline-block;
}

@keyframes projectappsMarqueeMove {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

.projectapps-shell {
  margin-top: 24px;
  text-align: center;
}

.projectapps-hint {
  margin-bottom: 10px;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: #0f766e;
}

.projectapps-stage {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  justify-items: center;
  min-height: 310px;
  transition: opacity .82s ease, transform .82s cubic-bezier(.22,.68,0,1);
}

.projectapps-stage.projectapps-moving {
  opacity: .96;
  transform: translateX(10px);
}

.projectapps-side {
  display: flex;
  align-items: center;
  gap: clamp(8px, 1.3vw, 18px);
}

.projectapps-left {
  justify-content: flex-end;
}

.projectapps-right {
  justify-content: flex-start;
}

.projectapps-item,
.projectapps-center {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.projectapps-center {
  flex-direction: column;
  width: 230px;
}

.projectapps-bubble,
.projectapps-center-bubble {
  position: relative;
  display: grid;
  place-items: center;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.78);
  overflow: visible;
  transition: width .28s ease, height .28s ease, opacity .28s ease, filter .28s ease, box-shadow .28s ease;
}

.projectapps-halo {
  position: absolute;
  inset: 8%;
  border-radius: 999px;
  filter: blur(16px);
  opacity: .46;
  z-index: 0;
}

.projectapps-logo {
  position: relative;
  z-index: 1;
  width: 84%;
  height: 84%;
  object-fit: contain;
  display: block;
}

.projectapps-center-bubble {
  width: 169px;
  height: 169px;
  opacity: 1;
  filter: saturate(1);
}

.projectapps-near-1 .projectapps-bubble {
  width: 108px;
  height: 108px;
  opacity: .66;
  filter: saturate(.88);
}

.projectapps-near-2 .projectapps-bubble {
  width: 88px;
  height: 88px;
  opacity: .52;
  filter: saturate(.78);
}

.projectapps-far-1 .projectapps-bubble {
  width: 70px;
  height: 70px;
  opacity: .36;
  filter: saturate(.64);
}

.projectapps-far-2 .projectapps-bubble {
  width: 54px;
  height: 54px;
  opacity: .24;
  filter: saturate(.50);
}

.projectapps-tagline {
  margin: 18px 0 0;
  width: max-content;
  max-width: min(520px, 86vw);
  text-align: center;
  font-size: 16px;
  font-weight: 900;
  color: #0f766e;
  line-height: 1.3;
  white-space: nowrap;
}

.projectapps-tooltip {
  position: absolute;
  left: 50%;
  bottom: calc(100% + 14px);
  width: min(380px, 82vw);
  transform: translateX(-50%) translateY(8px);
  padding: 13px 15px;
  border-radius: 16px;
  background: rgba(15, 23, 42, .95);
  color: white;
  text-align: center;
  box-shadow: 0 18px 38px rgba(15,23,42,.18), 0 0 0 1px rgba(255,255,255,.10) inset;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .22s ease, visibility .22s ease, transform .22s ease;
  z-index: 999;
}

.projectapps-tooltip::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -7px;
  width: 14px;
  height: 14px;
  transform: translateX(-50%) rotate(45deg);
  background: rgba(15, 23, 42, .95);
}

.projectapps-tooltip strong {
  display: block;
  font-size: 13px;
  line-height: 1.25;
  margin-bottom: 6px;
  color: #67e8f9;
}

.projectapps-tooltip p {
  margin: 0;
  font-size: 11px;
  line-height: 1.48;
  color: rgba(255,255,255,.86);
}

.projectapps-center:hover .projectapps-tooltip {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

.projectapps-dots {
  margin-top: 10px;
  display: flex;
  justify-content: center;
  gap: 8px;
}

.projectapps-dots span {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #cbd5e1;
}

.projectapps-dots span.active {
  width: 32px;
  background: #0f766e;
}

@media (max-width: 900px) {
  .projectapps-stage {
    grid-template-columns: 1fr auto 1fr;
    min-height: 280px;
  }

  .projectapps-side {
    gap: 8px;
  }

  .projectapps-center {
    width: 170px;
  }

  .projectapps-center-bubble {
    width: 130px;
    height: 130px;
  }

  .projectapps-near-1 .projectapps-bubble {
    width: 86px;
    height: 86px;
  }

  .projectapps-near-2 .projectapps-bubble {
    width: 70px;
    height: 70px;
  }

  .projectapps-far-1 .projectapps-bubble {
    width: 54px;
    height: 54px;
  }

  .projectapps-far-2 .projectapps-bubble {
    width: 42px;
    height: 42px;
  }

  .projectapps-tagline {
    font-size: 14px;
  }
}

@media (max-width: 620px) {
  .projectapps-stage {
    min-height: 250px;
  }

  .projectapps-center {
    width: 130px;
  }

  .projectapps-center-bubble {
    width: 104px;
    height: 104px;
  }

  .projectapps-near-1 .projectapps-bubble {
    width: 68px;
    height: 68px;
  }

  .projectapps-near-2 .projectapps-bubble {
    width: 54px;
    height: 54px;
  }

  .projectapps-far-1 .projectapps-bubble,
  .projectapps-far-2 .projectapps-bubble {
    display: none;
  }

  .projectapps-tagline {
    font-size: 12px;
    white-space: normal;
  }

  .projectapps-tooltip {
    width: min(300px, 90vw);
    padding: 11px 12px;
  }

  .projectapps-tooltip strong {
    font-size: 11px;
  }

  .projectapps-tooltip p {
    font-size: 9.5px;
    line-height: 1.38;
  }
}