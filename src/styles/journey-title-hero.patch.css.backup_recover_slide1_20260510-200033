/* === FORCE SLIDE 1 OPENING SEQUENCE FINAL START === */

#journey .journey-opening-line--one {
  opacity: 0 !important;
  width: 0 !important;
  max-width: none !important;
  overflow: hidden !important;
  white-space: nowrap !important;
  display: inline-block !important;
  animation:
    forceSlide1Line1Type 2500ms steps(34,end) 800ms forwards,
    forceSlide1LineFade 700ms ease 9000ms forwards !important;
}

#journey .journey-opening-line--two {
  opacity: 0 !important;
  width: 0 !important;
  max-width: none !important;
  overflow: hidden !important;
  white-space: nowrap !important;
  display: inline-block !important;
  animation:
    forceSlide1Line2Type 3600ms steps(46,end) 3600ms forwards,
    forceSlide1LineFade 700ms ease 9000ms forwards !important;
}

#journey .journey-opening-prologue {
  opacity: 1 !important;
  visibility: visible !important;
  animation: forceSlide1PrologueHide 700ms ease 9600ms forwards !important;
}

#journey .journey-code-stack {
  opacity: 0 !important;
  visibility: visible !important;
  transform: translateY(18px) scale(.98) !important;
  animation: forceSlide1HeaderShow 900ms ease 10300ms forwards !important;
}

#journey .journey-slide-footer {
  opacity: 0 !important;
  visibility: visible !important;
  transform: translateY(18px) !important;
  animation: forceSlide1FooterShow 1000ms ease 10800ms forwards !important;
}

#journey .journey-slide-footer * {
  visibility: visible !important;
}

@keyframes forceSlide1Line1Type {
  from { opacity: 1; width: 0; }
  to { opacity: 1; width: 34ch; }
}

@keyframes forceSlide1Line2Type {
  from { opacity: 1; width: 0; }
  to { opacity: 1; width: 46ch; }
}

@keyframes forceSlide1LineFade {
  from { opacity: 1; transform: translateY(0); }
  to { opacity: 0; transform: translateY(-18px); }
}

@keyframes forceSlide1PrologueHide {
  from { opacity: 1; visibility: visible; }
  to { opacity: 0; visibility: hidden; }
}

@keyframes forceSlide1HeaderShow {
  from { opacity: 0; transform: translateY(18px) scale(.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes forceSlide1FooterShow {
  from { opacity: 0; transform: translateY(18px); }
  to { opacity: 1; transform: translateY(0); }
}

/* === FORCE SLIDE 1 OPENING SEQUENCE FINAL END === */

