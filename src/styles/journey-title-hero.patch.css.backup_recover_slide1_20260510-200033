#journey .journey-panel[data-slide-index="5"] .journey-code-year,
#journey .journey-panel[data-slide-index="6"] .journey-code-year,
#journey .journey-panel[data-slide-index="7"] .journey-code-year,
#journey .journey-panel[data-slide-index="8"] .journey-code-year,
#journey .journey-panel[data-slide-index="9"] .journey-code-year,
#journey .journey-panel[data-slide-index="10"] .journey-code-year {
  font-size: clamp(23px, 3.6vw, 44px) !important;
